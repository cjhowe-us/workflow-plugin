{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-config.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "subagentStop": [
      {
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-worktree-state.py",
        "timeout": 30,
        "type": "command"
      }
    ]
  },
  "version": 1
}
