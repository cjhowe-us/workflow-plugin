{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-config.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-start-worktree-state.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-worktree-state.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-worktree-state.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  },
  "version": 1
}
