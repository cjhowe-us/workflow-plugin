{
  "scheme": "execution",
  "contract_version": 1,
  "fields": {
    "workflow":         { "type": "string", "required": true, "description": "Workflow name this execution instantiates." },
    "workflow_inputs":  { "type": "json",                       "description": "Inputs supplied to the workflow." },
    "parent_execution": { "type": "uri",                        "description": "Parent execution URI when this is a sub-workflow." },
    "owner":            { "type": "string",                     "description": "GitHub user (or other identity) currently holding the execution." },
    "status":           { "type": "enum",   "values": ["running", "needs_attention", "aborted", "complete"] },
    "title":            { "type": "string" },
    "body":             { "type": "markdown" },
    "assignees":        { "type": "array" },
    "url":              { "type": "string" }
  },
  "subcommands": {
    "create":  { "required": true,  "in": ["workflow", "workflow_inputs", "owner", "repo", "base", "head", "title", "summary"], "out": ["uri", "url", "status"] },
    "get":     { "required": true,  "in": ["uri"],                                                                                "out": ["uri", "title", "body", "status", "assignees", "url", "edges"] },
    "update":  { "required": true,  "in": ["uri", "patch"],                                                                       "out": ["uri", "updated"] },
    "list":    { "required": true,  "in": ["filter"],                                                                             "out": ["entries"] },
    "lock":    { "required": false, "in": ["uri", "owner"],                                                                       "out": ["held", "current_owner"] },
    "release": { "required": false, "in": ["uri", "owner"],                                                                       "out": ["released"] },
    "status":  { "required": true,  "in": ["uri"],                                                                                "out": ["uri", "status"] },
    "progress":{ "required": true,  "in": ["uri"],                                                                                "out": ["entries", "appended"] },
    "edges":   { "required": false, "relations": ["depends_on", "composed_of", "closes", "bundled_in"] }
  }
}
